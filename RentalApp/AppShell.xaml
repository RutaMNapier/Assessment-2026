<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RentalApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RentalApp.Views"
    Shell.FlyoutBehavior="Disabled">
    <TabBar>
        <Tab Title="Dashboard">
            <ShellContent Route="Dashboard" ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Browse Items">
            <ShellContent Route="BrowseItems" ContentTemplate="{DataTemplate views:ItemsListPage}" />
        </Tab>
        <Tab Title="List an Item">
            <ShellContent Route="ListAnItem" ContentTemplate="{DataTemplate views:CreateItemPage}" />
        </Tab>
        <Tab Title="Rentals">
            <ShellContent Route="Rentals" ContentTemplate="{DataTemplate views:RentalsPage}" />
        </Tab>
    </TabBar>
</Shell>