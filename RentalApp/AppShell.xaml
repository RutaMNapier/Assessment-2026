<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RentalApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RentalApp.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>

        <Tab Title="Browse Items">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsListPage}" />
        </Tab>

        <Tab Title="List an Item">
            <ShellContent ContentTemplate="{DataTemplate views:CreateItemPage}" />
        </Tab>

        <Tab Title="Rentals">
            <ShellContent ContentTemplate="{DataTemplate views:RentalsPage}" />
        </Tab>

        <Tab Title="Dashbroard">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

    </TabBar>

</Shell>