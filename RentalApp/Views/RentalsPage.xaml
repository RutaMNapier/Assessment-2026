<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RentalApp.Views.RentalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Rentals">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Incoming / Outgoing Toggle -->
        <HorizontalStackLayout Grid.Row="0"
                               HorizontalOptions="Center"
                               Padding="10"
                               Spacing="10">
            <Button Text="Incoming"
                    Command="{Binding ToggleViewCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    CornerRadius="8"
                    IsEnabled="{Binding ShowIncoming, Converter={StaticResource InvertedBoolConverter}}" />
            <Button Text="Outgoing"
                    Command="{Binding ToggleViewCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    CornerRadius="8"
                    IsEnabled="{Binding ShowIncoming}" />
        </HorizontalStackLayout>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           HorizontalOptions="Center" />

        <!-- Error Message -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                Padding="15"
                Margin="10,5"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                   FontSize="14" />
        </Border>

        <!-- Incoming Rentals -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Incoming}"
                        IsVisible="{Binding ShowIncoming}">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" VerticalOptions="Center">
                    <Label FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No incoming rentals"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,10,0,5" />
                    <Label Text="Rental requests for your items will appear here"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5"
                            Padding="15"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding ItemTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding BorrowerName, StringFormat='From: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                <Label Text="{Binding StartDate, StringFormat='{0:dd MMM yyyy}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    Padding="8,4"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Status}"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Outgoing Rentals -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Outgoing}"
                        IsVisible="{Binding ShowIncoming, Converter={StaticResource InvertedBoolConverter}}">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" VerticalOptions="Center">
                    <Label Text="🔍"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No outgoing rentals"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,10,0,5" />
                    <Label Text="Items you have requested to rent will appear here"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5"
                            Padding="15"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding ItemTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                <Label Text="{Binding StartDate, StringFormat='{0:dd MMM yyyy}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    Padding="8,4"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Status}"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>