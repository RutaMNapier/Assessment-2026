<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RentalApp.Views.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding Item.Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               Margin="0,20,0,0" />

            <!-- Error Message -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       FontSize="14" />
            </Border>

            <!-- Item Details Card -->
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">

                    <Label Text="{Binding Item.Title}"
                           FontSize="24"
                           FontAttributes="Bold" />

                    <Label Text="{Binding Item.Category}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                           FontSize="14" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="0,5" />

                    <Label Text="{Binding Item.Description}"
                           FontSize="15" />

                    <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                    <Label Text="{Binding Item.OwnerName, StringFormat='Owner: {0}'}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                           FontSize="14" />

                    <Label Text="Edinburgh, Scotland"
                            TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                            FontSize="13" />

                </VerticalStackLayout>
            </Border>

            <!-- Borrower Action -->
            <Button Text="Request Rental"
                    Command="{Binding RequestRentalCommand}"
                    IsVisible="{Binding IsOwner, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8" />

            <!-- Owner Action -->
            <Button Text="Edit Item"
                    Command="{Binding EditItemCommand}"
                    IsVisible="{Binding IsOwner}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    BorderWidth="1"
                    HeightRequest="50"
                    CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>